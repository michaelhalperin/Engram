{
  "name": "@michaelhalperin/engram",
  "version": "0.3.0",
  "description": "One memory. Every AI. Yours. A local-first, user-owned memory vault your AI tools plug into over MCP.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "memory",
    "ai",
    "claude",
    "local-first",
    "knowledge-base",
    "second-brain"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelhalperin/Engram.git"
  },
  "homepage": "https://github.com/michaelhalperin/Engram#readme",
  "bugs": "https://github.com/michaelhalperin/Engram/issues",
  "license": "MIT",
  "author": "Michael Halperin",
  "type": "module",
  "bin": {
    "engram": "dist/cli/main.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p src/ui/app/tsconfig.json && vite build",
